# SolarTwin agent layer config. Copy to .env and fill in.
# Everything works WITHOUT a key (deterministic mode); the key unlocks LLM prose + chatbot.

# Gemini (Google AI Studio) - paste your key here:
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Assumed feed-in tariff (EUR/kWh). No real tariff file is imported, so EUR is an estimate.
# Setting this value marks EUR as no-longer-assumption in labels.
# TARIFF_EUR_PER_KWH=0.10

# Plant label used in emails/UI.
PLANT_NAME=Plant A

# Real email sending is OFF by default (mock send writes to outputs/agents/emails/).
# To enable a real demo send to a SINGLE safe address (never the synthetic ones):
ENABLE_REAL_EMAIL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
SMTP_FROM=solartwin-agent@example.com
